---
import '../styles/global.css';
import {
  PUBLIC_SITE_URL,
  PUBLIC_BUSINESS_NAME,
  PUBLIC_BUSINESS_PHONE,
  PUBLIC_BUSINESS_PHONE_E164,
} from 'astro:env/client';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: PUBLIC_BUSINESS_NAME,
  url: PUBLIC_SITE_URL,
  telephone: PUBLIC_BUSINESS_PHONE_E164,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{PUBLIC_BUSINESS_NAME}</title>
    <meta name="description" content={`Website for ${PUBLIC_BUSINESS_NAME}`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <main>
      <h1>
        <img
          src="/img/logo-splitleaf.svg"
          alt={PUBLIC_BUSINESS_NAME}
          width="300"
          height="266"
          fetchpriority="high"
          decoding="async"
        />
      </h1>
      <nav class="social-links">
        <a href="https://www.github.com/seriouslysean">GitHub</a>
        <a href="https://www.linkedin.com/in/seriouslysean">LinkedIn</a>
      </nav>
    </main>
    <footer>
      <small>{PUBLIC_BUSINESS_NAME} · <a href={`tel:${PUBLIC_BUSINESS_PHONE_E164}`}>{PUBLIC_BUSINESS_PHONE}</a></small>
    </footer>
  </body>
</html>
